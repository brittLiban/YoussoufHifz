# ─── Database ───────────────────────────────────
DB_USER=youssouf
DB_PASSWORD=changeme_strong_password
DB_NAME=youssouf

# ─── Redis ──────────────────────────────────────
REDIS_PASSWORD=changeme_strong_password

# ─── MinIO (Audio Storage) ───────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_strong_password

# ─── JWT ────────────────────────────────────────
JWT_ACCESS_SECRET=generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=generate_with_openssl_rand_hex_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── API ────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_BASE_URL=https://api.yourdomain.com

# ─── Expo Push (for push notifications) ─────────
# No key needed — Expo Push is a stateless HTTP call
EXPO_ACCESS_TOKEN=

# ─── Email (Resend) ──────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
